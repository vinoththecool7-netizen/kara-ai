# Database
DATABASE_URL=postgresql+asyncpg://kara:kara@db:5432/kara

# LLM configuration
# Providers: openai | anthropic | ollama | fake (testing)
# For OpenRouter use LLM_PROVIDER=openai with LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o
LLM_PROVIDER=openai
LLM_BASE_URL=

# Embeddings (semantic search). Optional: without a working embedding
# backend Kara falls back to keyword search over the knowledge base.
# Providers: openai (uses LLM_API_KEY against api.openai.com) | ollama | fake
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
OLLAMA_BASE_URL=http://localhost:11434

# CORS (JSON array of allowed origins)
CORS_ORIGINS=["http://localhost:3000"]

# Debug mode
DEBUG=false
