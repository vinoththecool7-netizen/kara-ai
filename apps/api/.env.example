# OPTIONAL — a fresh install no longer needs this file: the web UI shows a
# first-run setup wizard and stores config in the database. Use this file
# when you want config locked in the environment: setting LLM_API_KEY (or a
# keyless LLM_PROVIDER like ollama/fake) takes precedence over and disables
# the wizard.

# Database
DATABASE_URL=postgresql+asyncpg://kara:kara@db:5432/kara

# LLM configuration
# Providers: openai | anthropic | ollama | fake (testing)
# For OpenRouter use LLM_PROVIDER=openai with LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o
LLM_PROVIDER=openai
LLM_BASE_URL=
# OpenRouter only: comma-separated fallback models tried in order when the
# primary model's pool is congested or rate-limited. Ignored elsewhere.
LLM_FALLBACK_MODELS=

# Embeddings (semantic search). Optional: without a working embedding
# backend Kara falls back to keyword search over the knowledge base.
# Providers: openai (uses LLM_API_KEY against api.openai.com) | ollama | fake
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
OLLAMA_BASE_URL=http://localhost:11434

# CORS (JSON array of allowed origins)
CORS_ORIGINS=["http://localhost:3000"]

# Host-header allowlist (JSON array). Blocks DNS-rebinding access to the
# unauthenticated API. Add your domain when serving behind a reverse proxy,
# e.g. ["localhost","127.0.0.1","api","kara.example.com"]. "api" is the
# compose-internal hostname the web proxy uses.
#ALLOWED_HOSTS=["localhost","127.0.0.1","api","test","testserver"]

# Only honour X-Forwarded-For for rate limiting when a trusted reverse proxy
# sits in front of the API. The header is client-spoofable; with this off,
# limits key on the direct client IP.
TRUST_PROXY_HEADERS=false

# Debug mode. Note: also enables SQL echo — full statements (including chat
# content) go to the logs. Never enable on a shared machine.
DEBUG=false
